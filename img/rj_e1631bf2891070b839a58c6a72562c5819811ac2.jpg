<script class="no_delay" type="text/javascript">
var mgTrackWidgetId = 1572999;
var mgTrackSiteId = 5365;
var mgTrackDomain = "diariodorio.com";

// Function to send events to Google Analytics
function mgTrackSendEvent(eventName) {
  if (typeof gtag === "function") {
    gtag("event", eventName);
    console.log(eventName + " detected.");
  } else {
    var timer = setInterval(function () {
      if (typeof gtag === "function") {
        clearInterval(timer);
        gtag("event", eventName);
        console.log(eventName + " detected.");
      }
    }, 100);
  }
}

// Detect Ad Request
if (typeof MutationObserver !== "undefined" && document.head) {
  var mgTrackMutationObserver = new MutationObserver(function (mutationList) {
    [].slice.call(mutationList).forEach(function (mutation) {
      if (mutation.addedNodes.length) {
        [].slice.call(mutation.addedNodes).forEach(function (node) {
          if (
            node.nodeName === "SCRIPT" &&
            node.src &&
            node.src.indexOf(
              "//servicer." + mgTrackDomain + "/" + mgTrackWidgetId + "/"
            ) !== -1 &&
            node.src.indexOf("rsh=") === -1
          ) {
            mgTrackSendEvent("MGID Ad Request");
          }
        });
      }
    });
  });

  mgTrackMutationObserver.observe(document.head, { childList: true });
}

// Detect Impression and Page View
if (typeof PerformanceObserver !== "undefined") {
  var mgTrackPerformanceObserver = new PerformanceObserver(function (list, _) {
    [].slice.call(list.getEntries()).forEach(function (entry) {
      if (entry.initiatorType === "img") {
        if (
          entry.name.indexOf("cid=" + mgTrackWidgetId) !== -1 &&
          ((entry.name.indexOf("//c." + mgTrackDomain + "/c") !== -1 &&
            entry.name.indexOf("f=1") !== -1) ||
            entry.name.indexOf("//c." + mgTrackDomain + "/w") !== -1)
        ) {
          mgTrackSendEvent("MGID Impression");
        }

        if (
          entry.name.indexOf("site=" + mgTrackSiteId) !== -1 &&
          entry.name.indexOf("//c." + mgTrackDomain + "/pv") !== -1
        ) {
          mgTrackSendEvent("MGID Page View");
        }
      }
    });
  });

  mgTrackPerformanceObserver.observe({ entryTypes: ["resource"] });
}
</script>
